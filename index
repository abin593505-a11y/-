
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RS Ranch 智能收入计算器</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #2E7D32;
            --primary-light: #4CAF50;
            --secondary: #FF9800;
            --accent: #2196F3;
            --dark: #1B5E20;
            --light: #F1F8E9;
            --white: #ffffff;
            --gray: #757575;
            --gray-light: #f5f5f5;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            --radius: 16px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', 'Segoe UI', sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
            color: #333;
            line-height: 1.6;
            padding: 20px;
            min-height: 100vh;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
            background-color: var(--white);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }
        
        header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--dark) 100%);
            color: var(--white);
            padding: 35px 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        
        header::before {
            content: "";
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
            background-size: 30px 30px;
            opacity: 0.1;
            z-index: 0;
        }
        
        h1 {
            font-size: 2.8rem;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            font-weight: 700;
            position: relative;
            z-index: 1;
        }
        
        h1 i {
            font-size: 2.5rem;
            color: #FFD700;
        }
        
        .subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
            max-width: 600px;
            margin: 0 auto;
            font-weight: 300;
            position: relative;
            z-index: 1;
        }
        
        .content-wrapper {
            padding: 40px;
        }
        
        .calculator-section {
            width: 100%;
        }
        
        .section-title {
            font-size: 1.6rem;
            color: var(--primary);
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 3px solid var(--primary-light);
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
        }
        
        .input-card {
            background: linear-gradient(135deg, var(--white) 0%, var(--gray-light) 100%);
            border-radius: var(--radius);
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            border: 2px solid rgba(76, 175, 80, 0.1);
        }
        
        .form-group {
            margin-bottom: 25px;
        }
        
        label {
            display: block;
            margin-bottom: 10px;
            font-weight: 600;
            color: var(--dark);
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        label i {
            color: var(--primary-light);
        }
        
        .input-with-icon {
            position: relative;
        }
        
        .input-with-icon i {
            position: absolute;
            left: 20px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--primary);
            font-size: 1.2rem;
        }
        
        input {
            width: 100%;
            padding: 18px 20px 18px 55px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-size: 1.1rem;
            transition: all 0.3s;
            background-color: var(--white);
            font-weight: 500;
        }
        
        input:focus {
            border-color: var(--primary-light);
            outline: none;
            box-shadow: 0 0 0 4px rgba(76, 175, 80, 0.15);
            transform: translateY(-2px);
        }
        
        .info-text {
            font-size: 0.95rem;
            color: var(--gray);
            margin-top: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .auto-level-info {
            background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
            border-radius: 12px;
            padding: 20px;
            margin-top: 20px;
            border-left: 5px solid var(--primary);
            display: none;
            animation: fadeIn 0.5s ease;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .level-display {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }
        
        .level-name {
            font-weight: 700;
            color: var(--dark);
            font-size: 1.3rem;
        }
        
        .stars {
            color: #FF9800;
            font-size: 1.5rem;
            letter-spacing: 2px;
        }
        
        .level-details {
            display: flex;
            justify-content: space-between;
            color: var(--gray);
            font-size: 0.95rem;
        }
        
        .calculate-btn {
            width: 100%;
            padding: 20px;
            background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 100%);
            color: var(--white);
            border: none;
            border-radius: 12px;
            font-size: 1.2rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-top: 10px;
            box-shadow: 0 5px 15px rgba(46, 125, 50, 0.3);
        }
        
        .calculate-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(46, 125, 50, 0.4);
        }
        
        .calculate-btn:active {
            transform: translateY(-1px);
        }
        
        .result-card {
            background: linear-gradient(135deg, var(--white) 0%, var(--gray-light) 100%);
            border-radius: var(--radius);
            padding: 30px;
            margin-top: 30px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            border-left: 5px solid var(--primary);
            display: none;
            animation: slideIn 0.6s ease;
        }
        
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .result-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid rgba(76, 175, 80, 0.2);
        }
        
        .result-title {
            font-size: 1.5rem;
            color: var(--dark);
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .result-badge {
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 700;
            font-size: 0.9rem;
        }
        
        .badge-penjaga {
            background-color: #FFF3E0;
            color: #EF6C00;
        }
        
        .badge-pakar {
            background-color: #E3F2FD;
            color: #1565C0;
        }
        
        .badge-rakan {
            background-color: #F3E5F5;
            color: #7B1FA2;
        }
        
        .income-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .income-card {
            background: var(--white);
            border-radius: 12px;
            padding: 25px 20px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            transition: transform 0.3s;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }
        
        .income-card:hover {
            transform: translateY(-5px);
        }
        
        .income-period {
            font-size: 1rem;
            color: var(--gray);
            margin-bottom: 10px;
            font-weight: 500;
        }
        
        .income-amount {
            font-size: 1.8rem;
            color: var(--primary);
            font-weight: 700;
            margin-bottom: 5px;
        }
        
        .income-rate {
            font-size: 0.9rem;
            color: var(--secondary);
            font-weight: 600;
        }
        
        .congrats-message {
            background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
            border-radius: 12px;
            padding: 25px;
            margin-top: 20px;
            border-left: 5px solid var(--primary);
            font-size: 1.05rem;
            line-height: 1.8;
            animation: fadeIn 0.8s ease;
        }
        
        .congrats-title {
            font-size: 1.3rem;
            color: var(--dark);
            font-weight: 700;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .congrats-line {
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .congrats-line i {
            color: var(--primary);
            font-size: 1.2rem;
        }
        
        .highlight {
            font-weight: 700;
            color: var(--dark);
        }
        
        .amount-highlight {
            color: #D84315;
            font-weight: 800;
        }
        
        .copy-btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, var(--accent) 0%, #1976D2 100%);
            color: var(--white);
            border: none;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-top: 20px;
            box-shadow: 0 5px 15px rgba(33, 150, 243, 0.3);
        }
        
        .copy-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(33, 150, 243, 0.4);
        }
        
        .level-rules {
            margin-top: 40px;
            padding: 25px;
            background: linear-gradient(135deg, var(--light) 0%, #E8F5E9 100%);
            border-radius: var(--radius);
            border: 2px solid rgba(76, 175, 80, 0.1);
        }
        
        .rules-title {
            font-size: 1.4rem;
            color: var(--dark);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .rules-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }
        
        .rule-card {
            background: var(--white);
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }
        
        .rule-level {
            font-weight: 700;
            color: var(--primary);
            font-size: 1.1rem;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .rule-details {
            font-size: 0.9rem;
            color: var(--gray);
            line-height: 1.6;
        }
        
        .footer {
            text-align: center;
            padding: 25px;
            background-color: var(--light);
            color: var(--gray);
            border-top: 1px solid rgba(0, 0, 0, 0.05);
            font-size: 0.9rem;
        }
        
        .footer a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }
        
        @media (max-width: 768px) {
            .content-wrapper {
                padding: 25px;
            }
            
            h1 {
                font-size: 2.2rem;
            }
            
            .income-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }
            
            .rules-grid {
                grid-template-columns: 1fr;
            }
        }
        
        @media (max-width: 480px) {
            .content-wrapper {
                padding: 20px;
            }
            
            header {
                padding: 25px 20px;
            }
            
            h1 {
                font-size: 1.8rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1><i class="fas fa-coins"></i> RS Ranch 智能收入计算器</h1>
            <p class="subtitle">输入储蓄余额，自动匹配职级星级并计算收入</p>
        </header>
        
        <div class="content-wrapper">
            <div class="calculator-section">
                <div class="section-title">
                    <i class="fas fa-calculator"></i> 智能收入计算
                </div>
                
                <div class="input-card">
                    <div class="form-group">
                        <label for="balance"><i class="fas fa-wallet"></i> 输入储蓄余额 (RM)</label>
                        <div class="input-with-icon">
                            <i class="fas fa-money-bill-wave"></i>
                            <input type="number" id="balance" min="0" step="10" value="5000" placeholder="例如：5000">
                        </div>
                        <p class="info-text">
                            <i class="fas fa-info-circle"></i> 系统将根据您的余额自动匹配对应职级和星级
                        </p>
                    </div>
                    
                    <div id="auto-level-info" class="auto-level-info">
                        <div class="level-display">
                            <div class="level-name" id="auto-level-name">Pakar Penternak★</div>
                            <div class="stars" id="auto-level-stars">⭐</div>
                        </div>
                        <div class="level-details">
                            <span id="auto-level-range">余额范围：RM5000-19999</span>
                            <span id="auto-level-rate">收入率：3.0%</span>
                        </div>
                    </div>
                    
                    <button id="calculate-btn" class="calculate-btn">
                        <i class="fas fa-calculator"></i> 计算我的收入
                    </button>
                </div>
                
                <div id="result" class="result-card">
                    <div class="result-header">
                        <div class="result-title">
                            <i class="fas fa-chart-line"></i> 收入计算结果
                        </div>
                        <div id="result-badge" class="result-badge badge-pakar">Pakar Penternak★</div>
                    </div>
                    
                    <div class="income-grid">
                        <div class="income-card">
                            <div class="income-period">每日收入</div>
                            <div class="income-amount" id="daily-income">RM125.00</div>
                            <div class="income-rate" id="daily-rate">收入率：3.0%</div>
                        </div>
                        
                        <div class="income-card">
                            <div class="income-period">30天收入</div>
                            <div class="income-amount" id="monthly-income">RM3,750.00</div>
                            <div class="income-rate">月收入</div>
                        </div>
                        
                        <div class="income-card">
                            <div class="income-period">365天收入</div>
                            <div class="income-amount" id="yearly-income">RM45,625.00</div>
                            <div class="income-rate">年收入</div>
                        </div>
                    </div>
                    
                    <div id="congrats-message" class="congrats-message">
                        <div class="congrats-title">
                            <i class="fas fa-trophy"></i> 恭喜晋升！
                        </div>
                        
                        <div class="congrats-line">
                            <i class="fas fa-star"></i>
                            <span>恭喜你成功晋升为 <span class="highlight" id="congrats-level">Pakar Penternak★</span>！</span>
                        </div>
                        
                        <div class="congrats-line">
                            <i class="fas fa-wallet"></i>
                            <span>你的储蓄钱包余额已达 <span class="amount-highlight" id="congrats-balance">RM5,000.00</span></span>
                        </div>
                        
                        <div class="congrats-line">
                            <i class="fas fa-coins"></i>
                            <span>每日收入 <span class="amount-highlight" id="congrats-daily">RM125.00</span></span>
                        </div>
                        
                        <div class="congrats-line">
                            <i class="fas fa-calendar-alt"></i>
                            <span>30天可获得 <span class="amount-highlight" id="congrats-monthly">RM3,750.00</span></span>
                        </div>
                        
                        <div class="congrats-line">
                            <i class="fas fa-calendar-day"></i>
                            <span>365天总收入高达 <span class="amount-highlight" id="congrats-yearly">RM45,625.00</span></span>
                        </div>
                        
                        <div class="congrats-line">
                            <i class="fas fa-rocket"></i>
                            <span>继续加油，未来更精彩！</span>
                        </div>
                    </div>
                    
                    <button id="copy-malay-btn" class="copy-btn">
                        <i class="fas fa-copy"></i> 复制马来语版本
                    </button>
                </div>
                
                <div class="level-rules">
                    <div class="rules-title">
                        <i class="fas fa-info-circle"></i> 职级匹配规则
                    </div>
                    
                    <div class="rules-grid">
                        <div class="rule-card">
                            <div class="rule-level"><i class="fas fa-user-tie"></i> Penjaga Lembu</div>
                            <div class="rule-details">
                                • RM30-499: ★ (2.0%)<br>
                                • RM500-999: ★★ (2.3%)<br>
                                • ≥RM1000: ★★★ (2.5%)
                            </div>
                        </div>
                        
                        <div class="rule-card">
                            <div class="rule-level"><i class="fas fa-user-graduate"></i> Pakar Penternak</div>
                            <div class="rule-details">
                                • RM1000-4999: ★ (2.5%)<br>
                                • RM5000-19999: ★ (3.0%)<br>
                                • RM20000-49999: ★★ (4.0%)
                            </div>
                        </div>
                        
                        <div class="rule-card">
                            <div class="rule-level"><i class="fas fa-crown"></i> Rakan Kongsi Ladang</div>
                            <div class="rule-details">
                                • RM50000-99999: ★ (5.0%)<br>
                                • ≥RM100000: ★★ (6.0%)<br>
                                • ≥RM200000: ★★★ (8.0%)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="footer">
            <p>© 2023 Ranch Sector Capital Management Ltd (RS) | 数据来源：RS收入结构图</p>
            <p style="margin-top: 8px;">此工具仅用于计算演示，实际收入可能受多种因素影响，请以官方数据为准。</p>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const balanceInput = document.getElementById('balance');
            const calculateBtn = document.getElementById('calculate-btn');
            const resultDiv = document.getElementById('result');
            const autoLevelInfo = document.getElementById('auto-level-info');
            const autoLevelName = document.getElementById('auto-level-name');
            const autoLevelStars = document.getElementById('auto-level-stars');
            const autoLevelRange = document.getElementById('auto-level-range');
            const autoLevelRate = document.getElementById('auto-level-rate');
            const copyMalayBtn = document.getElementById('copy-malay-btn');
            
            // 结果元素
            const resultBadge = document.getElementById('result-badge');
            const dailyIncomeEl = document.getElementById('daily-income');
            const monthlyIncomeEl = document.getElementById('monthly-income');
            const yearlyIncomeEl = document.getElementById('yearly-income');
            const dailyRateEl = document.getElementById('daily-rate');
            
            // 恭喜话术元素
            const congratsLevel = document.getElementById('congrats-level');
            const congratsBalance = document.getElementById('congrats-balance');
            const congratsDaily = document.getElementById('congrats-daily');
            const congratsMonthly = document.getElementById('congrats-monthly');
            const congratsYearly = document.getElementById('congrats-yearly');
            
            let currentMalayMessage = "";
            
            // 根据余额自动匹配职级和星级
            function autoMatchLevel(balance) {
                let positionName, positionNameMalay, badgeClass, dailyRate, starRating, levelRange, badgeType;
                
                // Penjaga Lembu
                if (balance >= 30 && balance <= 499) {
                    positionName = 'Penjaga Lembu★';
                    positionNameMalay = 'Penjaga Lembu★';
                    badgeClass = 'badge-penjaga';
                    dailyRate = 2.0;
                    starRating = '⭐';
                    levelRange = 'RM30-499';
                    badgeType = 'penjaga';
                } else if (balance >= 500 && balance <= 999) {
                    positionName = 'Penjaga Lembu★★';
                    positionNameMalay = 'Penjaga Lembu★★';
                    badgeClass = 'badge-penjaga';
                    dailyRate = 2.3;
                    starRating = '⭐⭐';
                    levelRange = 'RM500-999';
                    badgeType = 'penjaga';
                } else if (balance >= 1000 && balance <= 4999) {
                    positionName = 'Penjaga Lembu★★★';
                    positionNameMalay = 'Penjaga Lembu★★★';
                    badgeClass = 'badge-penjaga';
                    dailyRate = 2.5;
                    starRating = '⭐⭐⭐';
                    levelRange = '≥RM1000';
                    badgeType = 'penjaga';
                }
                // Pakar Penternak (调整范围：1000-4999已经是Penjaga，所以这里从5000开始)
                else if (balance >= 5000 && balance <= 19999) {
                    positionName = 'Pakar Penternak★';
                    positionNameMalay = 'Pakar Penternak★';
                    badgeClass = 'badge-pakar';
                    dailyRate = 3.0;
                    starRating = '⭐';
                    levelRange = 'RM5000-19999';
                    badgeType = 'pakar';
                } else if (balance >= 20000 && balance <= 49999) {
                    positionName = 'Pakar Penternak★★';
                    positionNameMalay = 'Pakar Penternak★★';
                    badgeClass = 'badge-pakar';
                    dailyRate = 4.0;
                    starRating = '⭐⭐';
                    levelRange = 'RM20000-49999';
                    badgeType = 'pakar';
                }
                // Rakan Kongsi Ladang
                else if (balance >= 50000 && balance <= 99999) {
                    positionName = 'Rakan Kongsi Ladang★';
                    positionNameMalay = 'Rakan Kongsi Ladang★';
                    badgeClass = 'badge-rakan';
                    dailyRate = 5.0;
                    starRating = '⭐';
                    levelRange = 'RM50000-99999';
                    badgeType = 'rakan';
                } else if (balance >= 100000 && balance < 200000) {
                    positionName = 'Rakan Kongsi Ladang★★';
                    positionNameMalay = 'Rakan Kongsi Ladang★★';
                    badgeClass = 'badge-rakan';
                    dailyRate = 6.0;
                    starRating = '⭐⭐';
                    levelRange = '≥RM100000';
                    badgeType = 'rakan';
                } else if (balance >= 200000) {
                    positionName = 'Rakan Kongsi Ladang★★★';
                    positionNameMalay = 'Rakan Kongsi Ladang★★★';
                    badgeClass = 'badge-rakan';
                    dailyRate = 8.0;
                    starRating = '⭐⭐⭐';
                    levelRange = '≥RM200000';
                    badgeType = 'rakan';
                } else {
                    // 余额不足最低要求
                    return null;
                }
                
                return {
                    positionName,
                    positionNameMalay,
                    badgeClass,
                    dailyRate,
                    starRating,
                    levelRange,
                    badgeType,
                    dailyIncome: (balance * dailyRate / 100)
                };
            }
            
            // 实时显示匹配的职级信息
            balanceInput.addEventListener('input', function() {
                const balance = parseFloat(balanceInput.value);
                
                if (isNaN(balance) || balance < 0) {
                    autoLevelInfo.style.display = 'none';
                    return;
                }
                
                const positionInfo = autoMatchLevel(balance);
                
                if (positionInfo) {
                    autoLevelName.textContent = positionInfo.positionName;
                    autoLevelStars.textContent = positionInfo.starRating;
                    autoLevelRange.textContent = `余额范围：${positionInfo.levelRange}`;
                    autoLevelRate.textContent = `收入率：${positionInfo.dailyRate}%`;
                    autoLevelInfo.style.display = 'block';
                } else {
                    autoLevelInfo.style.display = 'none';
                }
                
                // 隐藏结果
                resultDiv.style.display = 'none';
            });
            
            // 复制马来语消息
            copyMalayBtn.addEventListener('click', function() {
                navigator.clipboard.writeText(currentMalayMessage).then(function() {
                    alert('马来语消息已复制到剪贴板！');
                }).catch(function(err) {
                    console.error('复制失败: ', err);
                    alert('复制失败，请手动选择并复制文本。');
                });
            });
            
            // 计算收入
            calculateBtn.addEventListener('click', function() {
                const balance = parseFloat(balanceInput.value);
                
                if (isNaN(balance) || balance < 0) {
                    alert('请输入有效的余额数字');
                    return;
                }
                
                if (balance < 30) {
                    alert('最低储蓄余额为 RM30 才能计算收入');
                    return;
                }
                
                // 获取自动匹配的职级信息
                const positionInfo = autoMatchLevel(balance);
                
                if (!positionInfo) {
                    alert('无法匹配到合适的职级，请检查输入的余额');
                    return;
                }
                
                const { 
                    positionName, 
                    positionNameMalay, 
                    badgeClass, 
                    dailyRate, 
                    starRating,
                    dailyIncome,
                    badgeType
                } = positionInfo;
                
                // 计算总收入
                const monthlyIncome = dailyIncome * 30;
                const yearlyIncome = dailyIncome * 365;
                
                // 格式化金额显示
                const formatCurrency = (amount) => {
                    return 'RM' + amount.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
                };
                
                // 更新结果显示
                resultBadge.textContent = positionName;
                resultBadge.className = `result-badge ${badgeClass}`;
                dailyIncomeEl.textContent = formatCurrency(dailyIncome);
                monthlyIncomeEl.textContent = formatCurrency(monthlyIncome);
                yearlyIncomeEl.textContent = formatCurrency(yearlyIncome);
                dailyRateEl.textContent = `收入率：${dailyRate}%`;
                
                // 更新恭喜话术
                congratsLevel.textContent = positionName;
                congratsBalance.textContent = formatCurrency(balance);
                congratsDaily.textContent = formatCurrency(dailyIncome);
                congratsMonthly.textContent = formatCurrency(monthlyIncome);
                congratsYearly.textContent = formatCurrency(yearlyIncome);
                
                // 生成马来语版本
                currentMalayMessage = `🎉 Tahniah! Anda telah berjaya dinaikkan pangkat ke peringkat ${positionNameMalay}! 🎯\nBaki dompet simpanan anda telah mencapai ${formatCurrency(balance)} 💰\nPendapatan harian: ${formatCurrency(dailyIncome)} 💵\nPendapatan 30 hari: ${formatCurrency(monthlyIncome)} 💎\nJumlah pendapatan 365 hari: ${formatCurrency(yearlyIncome)} 🚀\nTeruskan usaha, masa depan lebih cerah! 🌟`;
                
                // 显示结果
                resultDiv.style.display = 'block';
                
                // 滚动到结果
                resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            });
            
            // 初始触发一次余额输入事件
            balanceInput.dispatchEvent(new Event('input'));
            
            // 初始计算一次
            calculateBtn.click();
        });
    </script>
</body>
</html>
